# 复制到 .env 或直接在 systemd unit 里设置

# ── 必填 ────────────────────────────────────────────────
# Groq Whisper API keys（多个用逗号分隔，自动轮询）
# 在 https://console.groq.com/keys 创建免费 key
GROQ_API_KEYS=gsk_xxx,gsk_yyy

# Web 访问密码（留空 = 不鉴权，公网部署千万别留空）
WEB_PASSWORD=changeme-please

# ── LLM 校对配置（默认 DeepSeek，留空则不校对）────────────
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-key
LLM_MODEL=deepseek-chat

# ── 可选 ────────────────────────────────────────────────
PORT=8088
HOST=0.0.0.0
